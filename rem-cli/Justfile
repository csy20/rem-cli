check:
    cargo check --all-targets

lint:
    cargo clippy --all-targets

fmt:
    cargo fmt --check

test:
    cargo test

test-all:
    cargo test -- --include-ignored

build:
    cargo build

build-release:
    cargo build --release

audit:
    cargo audit

outdated:
    cargo outdated

bench:
    cargo bench

clean:
    cargo clean

check-all: check lint fmt test

all: check lint fmt test build-release

check-audit: audit deny

.PHONY: check lint fmt test test-all build build-release audit outdated bench clean all check-all check-audit
